---
---
<section class="features" id="features">
  <div class="container">
    <div class="section-eyebrow reveal">What we offer</div>
    <h2 class="section-title reveal reveal-d1">Grow your passion</h2>
    <p class="section-desc reveal reveal-d2">Everything you need to discover, arrange, and celebrate the flowers you love.</p>
    <div class="bento-grid">
      <div class="bento-cell bento-cell--span reveal reveal-d1">
        <div class="bento-inner bento-inner--sage">
          <h3>Seasonal Curations</h3>
          <p>Hand-picked selections that change with the seasons, so your home always feels alive and current.</p>
        </div>
      </div>
      <div class="bento-cell bento-cell--image reveal reveal-d2">
        <div class="bento-inner">
          <img src="https://images.unsplash.com/photo-1444021465936-c6ca81d39b84?w=500&h=417&fit=crop&fm=webp&q=80" alt="Fresh cut flowers in a vase" width="500" height="417" loading="lazy" decoding="async">
          <div class="bento-label">Styled by Bloom</div>
        </div>
      </div>
      <div class="bento-cell bento-cell--image reveal reveal-d3">
        <div class="bento-inner">
          <img src="https://images.unsplash.com/photo-1561181286-d3fee7d55364?w=500&h=417&fit=crop&fm=webp&q=80" alt="Hands arranging pink flowers" width="500" height="417" loading="lazy" decoding="async">
          <div class="bento-label">Workshops</div>
        </div>
      </div>
      <div class="bento-cell reveal reveal-d2">
        <div class="bento-inner bento-inner--cream">
          <h3>Care Guides</h3>
          <p>Expert tips on keeping every variety fresh, vibrant, and thriving for longer.</p>
        </div>
      </div>
      <div class="bento-cell reveal reveal-d3">
        <div class="bento-inner bento-inner--blush">
          <h3>Gift Bundles</h3>
          <p>Thoughtfully wrapped arrangements delivered to someone you love.</p>
        </div>
      </div>
      <div class="bento-cell reveal reveal-d4">
        <div class="bento-inner bento-inner--dark">
          <h3>Grow Your Own</h3>
          <p>Seed kits and planting guides for starting your own cutting garden.</p>
        </div>
      </div>
    </div>
  </div>
</section>
