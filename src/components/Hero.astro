---
---
<section class="hero">
  <div class="hero-left">
    <div class="hero-badge reveal">
      <span class="dot"></span>
      New spring collection
    </div>
    <h1 class="reveal reveal-d1">Where every<br><em>petal</em> tells<br>a story</h1>
    <p class="hero-sub reveal reveal-d2">A curated space for flower lovers, garden dreamers, and anyone who believes a single bloom can change the mood of a room.</p>
    <div class="hero-actions reveal reveal-d3">
      <a href="#cta" class="btn-hero">
        Explore collections
        <span class="btn-icon">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 12l4-4-4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
      <a href="#features" class="btn-ghost">How it works</a>
    </div>
  </div>
  <div class="hero-right">
    <div class="hero-img-main reveal reveal-d2">
      <img src="https://images.unsplash.com/photo-1487530811176-3780de880c2d?w=900&h=1200&fit=crop&crop=center" alt="Lush pink peonies in soft morning light" loading="eager" fetchpriority="high">
    </div>
    <div class="hero-img-accent reveal reveal-d4">
      <img src="https://images.unsplash.com/photo-1457089328109-e5d9bd499191?w=500&h=600&fit=crop" alt="Close-up of fresh ranunculus" loading="eager">
    </div>
    <div class="hero-float-tag reveal reveal-d5">
      <div class="tag-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--sage-700)" stroke-width="1.5" stroke-linecap="round"><path d="M12 22c5.5-3 9-8.5 9-13A5 5 0 007 9c0 4.5 3.5 10 5 13z"/><circle cx="12" cy="9" r="1.5" fill="var(--sage-700)" stroke="none"/></svg>
      </div>
      <div>
        <div class="tag-text">Seasonal picks</div>
        <div class="tag-sub">Updated weekly</div>
      </div>
    </div>
  </div>
</section>
