---
---
<section class="gallery" id="gallery">
  <div class="container">
    <div class="section-eyebrow reveal">From the community</div>
    <h2 class="section-title reveal reveal-d1">From the garden</h2>
    <p class="section-desc reveal reveal-d2">Real moments from flower lovers, growers, and arrangers around the world.</p>
    <div class="gallery-grid">
      <div class="gallery-item reveal reveal-d1">
        <img src="https://images.unsplash.com/photo-1457089328109-e5d9bd499191?w=700&h=900&fit=crop" alt="Wildflower field at golden hour" loading="lazy">
        <span class="caption">Wildflower season</span>
      </div>
      <div class="gallery-item reveal reveal-d2">
        <img src="https://images.unsplash.com/photo-1487530811176-3780de880c2d?w=500&h=400&fit=crop" alt="Single stem in ceramic vase" loading="lazy">
        <span class="caption">Single stem series</span>
      </div>
      <div class="gallery-item reveal reveal-d3">
        <img src="https://images.unsplash.com/photo-1508610048659-a06b669e3321?w=500&h=400&fit=crop" alt="Lavender fields" loading="lazy">
        <span class="caption">Provence mornings</span>
      </div>
      <div class="gallery-item reveal reveal-d2">
        <img src="https://images.unsplash.com/photo-1455659817273-f96807779a8a?w=500&h=400&fit=crop" alt="Garden roses bouquet" loading="lazy">
        <span class="caption">Garden roses</span>
      </div>
      <div class="gallery-item reveal reveal-d3">
        <img src="https://images.unsplash.com/photo-1561181286-d3fee7d55364?w=500&h=400&fit=crop" alt="Peonies in pottery vase" loading="lazy">
        <span class="caption">Studio peonies</span>
      </div>
    </div>
  </div>
</section>
