<section class="cta-section" id="cta">
  <div class="container">
    <div class="cta-inner">
      <div class="section-eyebrow reveal" style="justify-content: center;">Stay in bloom</div>
      <h2 class="reveal reveal-d1">Start your<br>bloom journey</h2>
      <p class="reveal reveal-d2">Join a community of 12,000+ flower lovers. Get weekly seasonal picks, care tips, and early access to new collections.</p>
      <form class="cta-form reveal reveal-d3" onsubmit="event.preventDefault();">
        <input type="email" placeholder="your@email.com" aria-label="Email address" required>
        <button type="submit">Join free</button>
      </form>
    </div>
  </div>
</section>
