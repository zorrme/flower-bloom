---
interface Props {
  title?: string;
}

const { title = "Bloom — For Flower Lovers" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Bloom is a curated space for flower lovers, garden dreamers, and anyone who believes a single bloom can change the mood of a room.">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet"></noscript>
</head>
<body>
  <main>
    <slot />
  </main>
</body>
</html>

<style is:global>
    :root {
      --sage-900: #1a2e1f;
      --sage-800: #2a4a33;
      --sage-700: #3a6547;
      --sage-600: #4a7d5b;
      --sage-500: #4a8a5e;
      --sage-400: #8fb89e;
      --sage-100: #dce8df;
      --sage-50: #eef5f0;
      --cream: #f8f6f1;
      --cream-warm: #f2efe8;
      --blush: #a86b5e;
      --blush-soft: #e8c4bb;
      --ink: #1a1a18;
      --ink-muted: #5a5a56;
      --ink-faint: #6a6a64;
      --white: #fefefe;
      --white-warm: #faf8f4;
      --radius-lg: 24px;
      --radius-xl: 32px;
      --radius-pill: 100px;
      --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
      --ease-spring: cubic-bezier(0.32, 0.72, 0, 1);
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --cream: #0c0f0d;
        --cream-warm: #111613;
        --sage-50: #1a2e1f;
        --sage-100: #1e3524;
        --white: #151b17;
        --white-warm: #1a221d;
        --ink: #e4e2dc;
        --ink-muted: #8a8a86;
        --ink-faint: #5a5a56;
        --blush-soft: #3a2a26;
      }
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
    body {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      background: var(--cream);
      color: var(--ink);
      line-height: 1.6;
      overflow-x: hidden;
      position: relative;
    }
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 9999;
      pointer-events: none;
      opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 200px;
    }
    h1, h2, h3, h4 {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-weight: 400;
      line-height: 1.05;
    }
    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }

    /* ─── FLOATING PILL NAV ─── */
    .nav-pill {
      position: fixed;
      top: 20px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 1000;
      display: flex;
      align-items: center;
      gap: 32px;
      padding: 12px 14px 12px 28px;
      background: rgba(248, 246, 241, 0.8);
      backdrop-filter: blur(24px) saturate(1.4);
      -webkit-backdrop-filter: blur(24px) saturate(1.4);
      border: 1px solid rgba(26, 46, 31, 0.08);
      border-radius: var(--radius-pill);
      box-shadow: 0 1px 2px rgba(26,46,31,0.04), 0 8px 32px rgba(26,46,31,0.06), inset 0 1px 0 rgba(255,255,255,0.6);
      transition: all 0.5s var(--ease-out-expo);
    }
    @media (prefers-color-scheme: dark) {
      .nav-pill {
        background: rgba(12,15,13,0.82);
        border-color: rgba(255,255,255,0.06);
        box-shadow: 0 1px 2px rgba(0,0,0,0.1), 0 8px 32px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.04);
      }
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      font-size: 1.35rem;
      color: var(--sage-800);
    }
    @media (prefers-color-scheme: dark) { .nav-logo { color: var(--sage-400); } }
    .nav-logo span { color: var(--blush); }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 28px;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--ink-muted);
      transition: color 0.3s var(--ease-out-quart);
    }
    .nav-links a:hover { color: var(--sage-700); }
    @media (prefers-color-scheme: dark) { .nav-links a:hover { color: var(--sage-400); } }
    .nav-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 22px;
      background: var(--sage-900);
      color: var(--white);
      border-radius: var(--radius-pill);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      transition: transform 0.3s var(--ease-spring), box-shadow 0.3s var(--ease-out-quart);
      cursor: pointer;
      border: none;
    }
    .nav-cta:active { transform: scale(0.97); }
    .nav-cta:hover { box-shadow: 0 4px 20px rgba(26,46,31,0.25); }
    .nav-cta .cta-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: rgba(255,255,255,0.12);
      transition: transform 0.3s var(--ease-spring);
    }
    .nav-cta:hover .cta-icon { transform: translate(1px, -1px); }
    @media (prefers-color-scheme: dark) { .nav-cta { background: var(--sage-700); } }
    .nav-mobile-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      width: 40px;
      height: 40px;
      position: relative;
    }
    .nav-mobile-toggle span {
      display: block;
      width: 20px;
      height: 1.5px;
      background: var(--ink);
      position: absolute;
      left: 10px;
      transition: all 0.3s var(--ease-out-expo);
    }
    .nav-mobile-toggle span:nth-child(1) { top: 14px; }
    .nav-mobile-toggle span:nth-child(2) { top: 20px; }
    .nav-mobile-toggle span:nth-child(3) { top: 26px; }
    @media (max-width: 768px) {
      .nav-pill { width: calc(100% - 32px); padding: 10px 12px 10px 20px; gap: 12px; }
      .nav-links { display: none; }
      .nav-mobile-toggle { display: block; }
    }

    /* ─── HERO ─── */
    .hero {
      min-height: 100dvh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      padding: 120px 0 80px;
    }
    .hero-left {
      padding: 0 60px 0 clamp(40px, 8vw, 120px);
      max-width: 680px;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 16px 6px 10px;
      background: var(--sage-50);
      border: 1px solid rgba(26,46,31,0.06);
      border-radius: var(--radius-pill);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--sage-700);
      margin-bottom: 32px;
    }
    .hero-badge .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--sage-500);
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.8); }
    }
    .hero h1 {
      font-size: clamp(3rem, 6vw, 5.2rem);
      font-weight: 300;
      color: var(--ink);
      margin-bottom: 28px;
      letter-spacing: -0.03em;
      line-height: 1;
    }
    .hero h1 em {
      font-style: italic;
      font-weight: 400;
      color: var(--blush);
    }
    .hero-sub {
      font-size: 1.05rem;
      color: var(--ink-muted);
      max-width: 42ch;
      margin-bottom: 48px;
      line-height: 1.75;
    }
    .hero-actions {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }
    .btn-hero {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 16px 18px 16px 32px;
      background: var(--sage-900);
      color: var(--white);
      border-radius: var(--radius-pill);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      border: none;
      cursor: pointer;
      transition: transform 0.3s var(--ease-spring), box-shadow 0.4s var(--ease-out-expo);
    }
    .btn-hero:active { transform: scale(0.97); }
    .btn-hero:hover { box-shadow: 0 8px 40px rgba(26,46,31,0.3); }
    .btn-hero .btn-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px; height: 32px;
      border-radius: 50%;
      background: rgba(255,255,255,0.12);
      transition: transform 0.3s var(--ease-spring);
    }
    .btn-hero:hover .btn-icon { transform: translate(2px, -2px) scale(1.05); }
    .btn-hero:hover .btn-icon svg { transform: translate(1px, -1px); }
    @media (prefers-color-scheme: dark) { .btn-hero { background: var(--sage-600); } }
    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 16px 28px;
      border-radius: var(--radius-pill);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--ink-muted);
      border: 1px solid rgba(26,46,31,0.12);
      background: transparent;
      cursor: pointer;
      transition: all 0.3s var(--ease-out-quart);
    }
    .btn-ghost:hover { border-color: var(--sage-700); color: var(--sage-800); }
    @media (prefers-color-scheme: dark) {
      .btn-ghost { border-color: rgba(255,255,255,0.1); color: var(--ink-muted); }
      .btn-ghost:hover { border-color: var(--sage-400); color: var(--sage-400); }
    }
    .hero-right {
      position: relative;
      height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-img-main {
      position: absolute;
      width: 72%; height: 70%;
      border-radius: var(--radius-xl);
      overflow: hidden;
      top: 12%; right: 8%;
    }
    .hero-img-main img { width: 100%; height: 100%; object-fit: cover; }
    .hero-img-accent {
      position: absolute;
      width: 40%; height: 38%;
      border-radius: var(--radius-lg);
      overflow: hidden;
      bottom: 14%; left: 4%;
      border: 4px solid var(--cream);
      box-shadow: 0 20px 60px rgba(26,46,31,0.15);
    }
    .hero-img-accent img { width: 100%; height: 100%; object-fit: cover; }
    .hero-float-tag {
      position: absolute;
      bottom: 38%; right: 2%;
      background: var(--white);
      border: 1px solid rgba(26,46,31,0.06);
      border-radius: var(--radius-lg);
      padding: 14px 20px;
      box-shadow: 0 8px 32px rgba(26,46,31,0.08);
      display: flex;
      align-items: center;
      gap: 12px;
      z-index: 2;
    }
    .hero-float-tag .tag-icon {
      width: 36px; height: 36px;
      border-radius: 10px;
      background: var(--sage-50);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-float-tag .tag-text { font-size: 0.78rem; font-weight: 600; color: var(--ink); }
    .hero-float-tag .tag-sub { font-size: 0.7rem; color: var(--ink-muted); }
    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; min-height: auto; padding: 100px 0 40px; }
      .hero-left { padding: 0 24px; max-width: 100%; }
      .hero-right { height: 55dvh; }
      .hero-img-main { width: 80%; height: 85%; top: 0; right: 0; }
      .hero-img-accent { width: 45%; height: 40%; bottom: 0; left: 0; }
      .hero-float-tag { display: none; }
    }

    /* ─── MARQUEE ─── */
    .marquee-section {
      padding: 40px 0;
      border-top: 1px solid rgba(26,46,31,0.06);
      border-bottom: 1px solid rgba(26,46,31,0.06);
      overflow: hidden;
    }
    .marquee-track {
      display: flex;
      align-items: center;
      gap: 56px;
      width: max-content;
      animation: marquee 30s linear infinite;
    }
    .marquee-item {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-style: italic;
      color: var(--ink-faint);
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .marquee-dot {
      width: 4px; height: 4px; border-radius: 50%;
      background: var(--blush); opacity: 0.5;
    }
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ─── FEATURES ─── */
    .features { padding: clamp(80px, 12vw, 160px) 0; }
    .container { max-width: 1320px; margin: 0 auto; padding: 0 clamp(20px, 4vw, 48px); }
    .section-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 5px 14px;
      background: var(--sage-50);
      border-radius: var(--radius-pill);
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--sage-700);
      margin-bottom: 20px;
    }
    .section-title {
      font-size: clamp(2.2rem, 4.5vw, 3.8rem);
      color: var(--ink);
      margin-bottom: 16px;
      letter-spacing: -0.025em;
      max-width: 500px;
    }
    .section-desc {
      color: var(--ink-muted);
      font-size: 1rem;
      line-height: 1.75;
      max-width: 44ch;
      margin-bottom: 72px;
    }
    .bento-grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      grid-template-rows: 320px 320px;
      gap: 16px;
    }
    .bento-cell {
      position: relative;
      border-radius: var(--radius-xl);
      overflow: hidden;
      padding: 3px;
      background: rgba(26,46,31,0.04);
      border: 1px solid rgba(26,46,31,0.05);
      transition: transform 0.5s var(--ease-out-expo), box-shadow 0.5s var(--ease-out-expo);
    }
    @media (prefers-color-scheme: dark) {
      .bento-cell { background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.04); }
    }
    .bento-cell:hover {
      transform: translateY(-3px);
      box-shadow: 0 20px 60px rgba(26,46,31,0.1);
    }
    .bento-inner {
      border-radius: calc(var(--radius-xl) - 3px);
      padding: 32px 28px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      height: 100%;
      position: relative;
      overflow: hidden;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.5);
    }
    @media (prefers-color-scheme: dark) {
      .bento-inner { box-shadow: inset 0 1px 0 rgba(255,255,255,0.03); }
    }
    .bento-inner--sage { background: linear-gradient(160deg, var(--sage-50) 0%, var(--sage-100) 100%); }
    .bento-inner--cream { background: var(--white-warm); }
    .bento-inner--blush { background: linear-gradient(160deg, var(--blush-soft) 0%, #f0d5cc 100%); }
    .bento-inner--dark { background: var(--sage-900); color: var(--white); }
    .bento-cell h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      font-weight: 500;
      margin-bottom: 8px;
    }
    .bento-inner--dark h3 { color: var(--white); }
    .bento-cell p { font-size: 0.88rem; line-height: 1.6; color: var(--ink-muted); max-width: 34ch; }
    .bento-inner--dark p { color: rgba(255,255,255,0.6); }
    .bento-cell--image { padding: 3px; }
    .bento-cell--image .bento-inner { padding: 0; }
    .bento-cell--image img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.8s var(--ease-out-expo);
    }
    .bento-cell--image:hover img { transform: scale(1.04); }
    .bento-cell--image .bento-label {
      position: absolute;
      bottom: 20px; left: 20px;
      background: rgba(12,15,13,0.6);
      backdrop-filter: blur(16px);
      padding: 10px 18px;
      border-radius: var(--radius-pill);
      color: var(--white);
      font-size: 0.78rem;
      font-weight: 500;
      border: 1px solid rgba(255,255,255,0.08);
    }
    .bento-cell--span { grid-row: span 2; }
    @media (max-width: 768px) {
      .bento-grid { grid-template-columns: 1fr; grid-template-rows: auto; }
      .bento-cell { min-height: 260px; }
      .bento-cell--span { grid-row: span 1; }
    }

    /* ─── GALLERY ─── */
    .gallery {
      padding: clamp(80px, 12vw, 160px) 0;
      background: var(--sage-900);
      color: var(--white);
    }
    .gallery .section-title { color: var(--sage-50); }
    .gallery .section-desc { color: rgba(255,255,255,0.5); }
    .gallery .section-eyebrow { background: rgba(255,255,255,0.06); color: var(--sage-400); }
    .gallery-grid {
      display: grid;
      grid-template-columns: 1.3fr 1fr 0.9fr;
      grid-template-rows: 300px 280px;
      gap: 12px;
    }
    .gallery-grid .gallery-item:first-child { grid-row: span 2; }
    .gallery-item {
      border-radius: var(--radius-lg);
      overflow: hidden;
      position: relative;
    }
    .gallery-item img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.8s var(--ease-out-expo);
    }
    .gallery-item:hover img { transform: scale(1.05); }
    .gallery-item .caption {
      position: absolute;
      bottom: 16px; left: 16px;
      background: rgba(12,15,13,0.55);
      backdrop-filter: blur(16px);
      padding: 8px 16px;
      border-radius: var(--radius-pill);
      font-size: 0.72rem;
      font-weight: 500;
      color: rgba(255,255,255,0.85);
      border: 1px solid rgba(255,255,255,0.06);
    }
    @media (max-width: 768px) {
      .gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: 200px 180px 180px; }
      .gallery-grid .gallery-item:first-child { grid-column: span 2; grid-row: span 1; }
    }

    /* ─── TESTIMONIALS ─── */
    .testimonials { padding: clamp(80px, 12vw, 160px) 0; }
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .testimonial-card {
      background: var(--white-warm);
      border: 1px solid rgba(26,46,31,0.05);
      border-radius: var(--radius-xl);
      padding: 36px 32px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      position: relative;
      overflow: hidden;
    }
    .testimonial-card::before {
      content: '\201C';
      position: absolute;
      top: 16px; right: 24px;
      font-family: 'Cormorant Garamond', serif;
      font-size: 5rem;
      color: var(--sage-100);
      line-height: 1;
      pointer-events: none;
    }
    @media (prefers-color-scheme: dark) {
      .testimonial-card { background: var(--white); border-color: rgba(255,255,255,0.04); }
      .testimonial-card::before { color: var(--sage-50); }
    }
    .testimonial-card .stars { display: flex; gap: 2px; }
    .testimonial-card .stars svg { width: 15px; height: 15px; fill: var(--blush); }
    .testimonial-card blockquote {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      font-style: italic;
      line-height: 1.6;
      color: var(--ink);
      flex: 1;
    }
    .testimonial-card .author {
      display: flex;
      align-items: center;
      gap: 12px;
      border-top: 1px solid rgba(26,46,31,0.06);
      padding-top: 16px;
    }
    .testimonial-card .author-avatar {
      width: 40px; height: 40px;
      border-radius: 50%;
      object-fit: cover;
    }
    .testimonial-card .author-name {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 600;
      font-size: 0.85rem;
      color: var(--ink);
    }
    .testimonial-card .author-role { font-size: 0.78rem; color: var(--ink-muted); }
    @media (max-width: 768px) { .testimonials-grid { grid-template-columns: 1fr; } }

    /* ─── CTA ─── */
    .cta-section { padding: clamp(80px, 12vw, 160px) 0; text-align: center; }
    .cta-inner { max-width: 640px; margin: 0 auto; }
